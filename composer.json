{
    "name": "escalated-dev/escalated-laravel",
    "description": "An embeddable support ticket system for Laravel applications",
    "keywords": ["laravel", "support", "tickets", "helpdesk", "customer-support"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "inertiajs/inertia-laravel": "^2.0|^3.0"
    },
    "require-dev": {
        "inertiajs/inertia-laravel": "^2.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Escalated\\Laravel\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Escalated\\Laravel\\Tests\\": "tests/",
            "Escalated\\Laravel\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Escalated\\Laravel\\EscalatedServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
